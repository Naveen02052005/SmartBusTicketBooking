<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Conductor Portal - Smart Bus Booking</title>
    <link rel="stylesheet" href="/css/Interface.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        .logo{
            font-size: 30px;
            margin-left: 38%;
        }
        .loginConductor{
            margin-left: -20px;
        }

        .login-det{
            margin-right: 40px;
        }
        .login-det1{
            margin-right: 40px;
        }
        .conductor-hero {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 60px 20px;
            text-align: center;
            border-radius: 15px;
            margin: 20px 0;
        }
        
        .conductor-hero h1 {
            font-size: 2.5rem;
            margin-bottom: 15px;
        }
        
        .conductor-hero p {
            font-size: 1.2rem;
            opacity: 0.9;
        }
        
        .conductor-features {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 25px;
            margin: 40px 0;
        }
        
        .feature-card {
            background: white;
            padding: 25px;
            border-radius: 12px;
            box-shadow: 0 8px 25px rgba(0,0,0,0.1);
            text-align: center;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }
        
        .feature-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 35px rgba(0,0,0,0.15);
        }
        
        .feature-icon {
            width: 70px;
            height: 70px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
            color: white;
            font-size: 1.5rem;
        }
        
        .feature-card h3 {
            color: #2c3e50;
            margin-bottom: 12px;
            font-size: 1.3rem;
        }
        
        .feature-card p {
            color: #7f8c8d;
            line-height: 1.6;
        }
        
        .conductor-actions {
            text-align: center;
            margin: 40px 0;
        }
        
        .btn-primary {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 15px 40px;
            border: none;
            border-radius: 25px;
            font-size: 1.1rem;
            cursor: pointer;
            text-decoration: none;
            display: inline-block;
            margin: 10px;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }
        
        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px rgba(102, 126, 234, 0.4);
        }
        
        .btn-secondary {
            background: white;
            color: #667eea;
            padding: 15px 40px;
            border: 2px solid #667eea;
            border-radius: 25px;
            font-size: 1.1rem;
            cursor: pointer;
            text-decoration: none;
            display: inline-block;
            margin: 10px;
            transition: all 0.3s ease;
        }
        
        .btn-secondary:hover {
            background: #667eea;
            color: white;
        }
        
        .stats-container {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin: 30px 0;
        }
        
        .stat-card {
            background: white;
            padding: 20px;
            border-radius: 10px;
            text-align: center;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        }
        
        .stat-number {
            font-size: 2rem;
            font-weight: bold;
            color: #667eea;
        }
        
        .stat-label {
            color: #7f8c8d;
            margin-top: 5px;
        }
        
        .quick-links {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin: 30px 0;
            flex-wrap: wrap;
        }
        
        .quick-link {
            background: rgba(102, 126, 234, 0.1);
            color: #667eea;
            padding: 10px 20px;
            border-radius: 20px;
            text-decoration: none;
            transition: all 0.3s ease;
        }
        
        .quick-link:hover {
            background: #667eea;
            color: white;
        }
    </style>
</head>
<body>
    <div class="container">
        <header>
            <div class="logo">
                <!-- <i class="fa-solid fa-bus"></i> -->
                <!-- <span>Smart Bus Booking</span> -->
            </div>
            <nav class="navBar2">
                <a href="/home">Home</a>
                <a href="#" class="active">Dashboard</a>
                <div class="loginConductor">
                    <% if(isLogged) { %>
                        <a class="login-det" href="/conductor/logout">Logout</a>
                    <% } else { %>
                        <a class="login-det1" href="/conductor/login">Login</a>
                        <a class="registration-det" href="/conductor/registration">Registration</a>
                    <% } %>
                </div>
            </nav>
        </header>

        <main>
            <div class="conductor-hero">
                <h1>Conductor Portal</h1>
                <p>Manage your daily operations, scan tickets, and track passenger boarding</p>
            </div>

            <div class="stats-container">
                <div class="stat-card">
                    <div class="stat-number">0</div>
                    <div class="stat-label">Today's Boardings</div>
                </div>
                <div class="stat-card">
                    <div class="stat-number">0</div>
                    <div class="stat-label">Active Tickets</div>
                </div>
                <div class="stat-card">
                    <div class="stat-number">₹0</div>
                    <div class="stat-label">Today's Revenue</div>
                </div>
                <div class="stat-card">
                    <div class="stat-number">0</div>
                    <div class="stat-label">Completed Journeys</div>
                </div>
            </div>

            <div class="conductor-features">
                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="fas fa-qrcode"></i>
                    </div>
                    <h3>QR Scanner</h3>
                    <p>Scan passenger QR codes instantly for quick boarding verification and ticket validation</p>
                </div>
                
                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="fas fa-ticket-alt"></i>
                    </div>
                    <h3>Ticket Management</h3>
                    <p>View active tickets, manage passenger boarding, and track journey status in real-time</p>
                </div>
                
                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="fas fa-chart-line"></i>
                    </div>
                    <h3>Live Statistics</h3>
                    <p>Monitor boarding progress, revenue collection, and journey completion rates</p>
                </div>
                
                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="fas fa-route"></i>
                    </div>
                    <h3>Route Management</h3>
                    <p>Manage assigned routes, track journey progress, and handle route-specific operations</p>
                </div>
                
                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="fas fa-users"></i>
                    </div>
                    <h3>Passenger Info</h3>
                    <p>Access passenger details, boarding information, and ticket history</p>
                </div>
                
                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="fas fa-bell"></i>
                    </div>
                    <h3>Notifications</h3>
                    <p>Receive real-time alerts for important updates and system notifications</p>
                </div>
            </div>

            <div class="conductor-actions">
                <a href="/conductor/active" class="btn-primary">
                    <i class="fas fa-sign-in-alt mr-2"></i>
                    Start Journey
                </a>
                <a href="/conductor/registration" class="btn-secondary">
                    <i class="fas fa-user-plus mr-2"></i>
                    New Conductor
                </a>
            </div>

            <div class="quick-links">
                <a href="/conductor/login" class="quick-link">
                    <i class="fas fa-sign-in-alt mr-1"></i> Login
                </a>
                <a href="/conductor/registration" class="quick-link">
                    <i class="fas fa-user-plus mr-1"></i> Register
                </a>
                <a href="/conductor/login" class="quick-link">
                    <i class="fas fa-qrcode mr-1"></i> Scanner
                </a>
                <a href="/home" class="quick-link">
                    <i class="fas fa-home mr-1"></i> Home
                </a>
            </div>
        </main>
    </div>

    <script>
        // Simulate real-time stats updates
        function updateStats() {
            const stats = {
                boardings: Math.floor(Math.random() * 50) + 10,
                active: Math.floor(Math.random() * 30) + 5,
                revenue: Math.floor(Math.random() * 5000) + 1000,
                completed: Math.floor(Math.random() * 20) + 3
            };

            document.querySelectorAll('.stat-number').forEach((element, index) => {
                const values = [stats.boardings, stats.active, `₹${stats.revenue}`, stats.completed];
                element.textContent = values[index];
            });
        }

        // Update stats every 5 seconds
        updateStats();
        setInterval(updateStats, 5000);

        // Add hover effects to feature cards
        document.querySelectorAll('.feature-card').forEach(card => {
            card.addEventListener('mouseenter', function() {
                this.style.transform = 'translateY(-10px) scale(1.02)';
            });
            
            card.addEventListener('mouseleave', function() {
                this.style.transform = 'translateY(0) scale(1)';
            });
        });
    </script>
</body>
</html>