<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Conductor Registration - Smart Bus Booking</title>
    <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        .gradient-bg {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        }
        .glass-effect {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.18);
        }
        .error-message {
            color: #ef4444;
            font-size: 0.875rem;
            margin-top: 0.25rem;
        }
        .success-message {
            color: #10b981;
            font-size: 0.875rem;
            margin-top: 0.25rem;
        }
    </style>
</head>
<body class="gradient-bg min-h-screen flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-md w-full space-y-8">
        <!-- Header -->
        <div class="text-center">
            <h2 class="mt-6 text-3xl font-extrabold text-white">
                Conductor Registration
            </h2>
            <p class="mt-2 text-sm text-white">
                Join our team of professional conductors
            </p>
        </div>

        <!-- Registration Form -->
        <div class="glass-effect mt-8 rounded-xl shadow-2xl p-8">
            <form class="space-y-6" onsubmit="return validateForm()" action="/conductor/registration" method="POST" id="conductorRegistrationForm">
                <% if (error && error.length > 0) { %>
                    <div class="mb-4 p-3 bg-red-100 border border-red-400 text-red-700 rounded-lg">
                        <%= error %>
                    </div>
                <% } %>

                <% if (success && success.length > 0) { %>
                    <div class="mb-4 p-3 bg-green-100 border border-green-400 text-green-700 rounded-lg">
                        <%= success %>
                    </div>
                <% } %>

                <!-- Personal Information -->
                <div class="space-y-4">
                    <h3 class="text-lg font-medium text-gray-900 mb-4">Personal Information</h3>
                    
                    <!-- Full Name -->
                    <div>
                        <label for="fullName" class="block text-sm font-medium text-gray-700">
                            Full Name
                        </label>
                        <div class="mt-1 relative">
                            <input 
                                id="fullName" 
                                name="fullName" 
                                type="text"  
                                class="appearance-none rounded-lg relative block w-full px-3 py-2 border border-gray-300 placeholder-gray-500 text-gray-900 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 focus:z-10 sm:text-sm"
                                placeholder="Enter your full name"
                            >
                            <div class="absolute inset-y-0 right-0 pr-3 flex items-center">
                                <i class="fas fa-user text-gray-400"></i>
                            </div>
                        </div>
                        <span id="fullName-error" class="error-message text-red-500 text-sm">
                            <%= typeof errors !== 'undefined' && errors.fullName ? errors.fullName : '' %>
                        </span>
                    </div>

                    <!-- Employee ID -->
                    <div>
                        <label for="employeeId" class="block text-sm font-medium text-gray-700">
                            Employee ID
                        </label>
                        <div class="mt-1 relative">
                            <input 
                                id="employeeId" 
                                name="employeeId" 
                                type="text" 
                                class="appearance-none rounded-lg relative block w-full px-3 py-2 border border-gray-300 placeholder-gray-500 text-gray-900 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 focus:z-10 sm:text-sm"
                                placeholder="Enter your employee ID"
                            >
                            <div class="absolute inset-y-0 right-0 pr-3 flex items-center">
                                <i class="fas fa-id-badge text-gray-400"></i>
                            </div>
                        </div>
                       <span id="employeeId-error" class="error-message text-red-500 text-sm">
                            <%= typeof errors !== 'undefined' && errors.employeeId ? errors.employeeId : '' %>
                        </span>
                    </div>

                    <!-- Email -->
                    <div>
                        <label for="email" class="block text-sm font-medium text-gray-700">
                            Email Address
                        </label>
                        <div class="mt-1 relative">
                            <input 
                                id="email" 
                                name="email" 
                                type="email" 
                                class="appearance-none rounded-lg relative block w-full px-3 py-2 border border-gray-300 placeholder-gray-500 text-gray-900 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 focus:z-10 sm:text-sm"
                                placeholder="conductor@buscompany.com"
                            >
                            <div class="absolute inset-y-0 right-0 pr-3 flex items-center">
                                <i class="fas fa-envelope text-gray-400"></i>
                            </div>
                        </div>
                        <span id="email-error" class="error-message text-red-500 text-sm">
                            <%= typeof errors !== 'undefined' && errors.email ? errors.email : '' %>
                        </span>
                    </div>

                    <!-- Phone -->
                    <div>
                        <label for="phone" class="block text-sm font-medium text-gray-700">
                            Phone Number
                        </label>
                        <div class="mt-1 relative">
                            <input 
                                id="phone" 
                                name="phone" 
                                type="tel" 
                                class="appearance-none rounded-lg relative block w-full px-3 py-2 border border-gray-300 placeholder-gray-500 text-gray-900 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 focus:z-10 sm:text-sm"
                                placeholder="+91 98765 43210"
                            >
                            <div class="absolute inset-y-0 right-0 pr-3 flex items-center">
                                <i class="fas fa-phone text-gray-400"></i>
                            </div>
                        </div>
                        <span id="phone-error" class="error-message text-red-500 text-sm">
                            <%= typeof errors !== 'undefined' && errors.phone ? errors.phone : '' %>
                        </span>
                    </div>
                </div>

                <!-- Professional Information -->
                <div class="space-y-4 pt-6 border-t border-gray-200">
                    <h3 class="text-lg font-medium text-gray-900 mb-4">Professional Information</h3>
                    
                    <!-- License Number -->
                    <div>
                        <label for="licenseNumber" class="block text-sm font-medium text-gray-700">
                            Driving License Number
                        </label>
                        <div class="mt-1 relative">
                            <input 
                                id="licenseNumber" 
                                name="licenseNumber" 
                                type="text" 
                                class="appearance-none rounded-lg relative block w-full px-3 py-2 border border-gray-300 placeholder-gray-500 text-gray-900 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 focus:z-10 sm:text-sm"
                                placeholder="DL-1234567890123"
                            >
                            <div class="absolute inset-y-0 right-0 pr-3 flex items-center">
                                <i class="fas fa-id-card text-gray-400"></i>
                            </div>
                        </div>
                        <span id="licenseNumber-error" class="error-message text-red-500 text-sm">
                            <%= typeof errors !== 'undefined' && errors.licenseNumber ? errors.licenseNumber : '' %>
                        </span>
                    </div>
                </div>

                <!-- Account Security -->
                <div class="space-y-4 pt-6 border-t border-gray-200">
                    <h3 class="text-lg font-medium text-gray-900 mb-4">Account Security</h3>
                    
                    <!-- Password -->
                    <div>
                        <label for="password" class="block text-sm font-medium text-gray-700">
                            Password
                        </label>
                        <div class="mt-1 relative">
                            <input 
                                id="password" 
                                name="password" 
                                type="password" 
                                class="w-full rounded-lg relative block w-full px-3 py-2 border border-gray-300 placeholder-gray-500 text-gray-900 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 focus:z-10 sm:text-sm"
                                placeholder="Create a strong password"
                            >
                            <div class="absolute inset-y-0 right-0 pr-3 flex items-center">
                                <i class="fa-solid fa-eye cursor-pointer text-gray-500" id="togglePassword"></i>
                            </div>
                        </div>
                        <span id="password-error" class="error-message text-red-500 text-sm">
                            <%= typeof errors !== 'undefined' && errors.password ? errors.password : '' %>
                        </span>
                    </div>

                    <!-- Confirm Password -->
                    <div>
                        <label for="confirmPassword" class="block text-sm font-medium text-gray-700">
                            Confirm Password
                        </label>
                        <div class="mt-1 relative">
                            <input 
                                id="confirmPassword" 
                                name="confirmPassword" 
                                type="password" 
                                class="w-full pr-10 px-3 py-2 border border-gray-300 rounded-lg text-gray-900 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm"
                                placeholder="Confirm your password"
                            >
                            <div class="absolute inset-y-0 right-0 pr-3 flex items-center">
                                <i class="fa-solid fa-eye cursor-pointer text-gray-500" id="toggleConfirmPassword"></i>
                            </div>
                        </div>
                        <span id="confirmPassword-error" class="error-message text-red-500 text-sm">
                            <%= typeof errors !== 'undefined' && errors.confirmPassword ? errors.confirmPassword : '' %>
                        </span>
                    </div>
                </div>

                <!-- Terms and Submit -->
                <div class="space-y-4 pt-6 border-t border-gray-200">
                    <div class="flex items-center">
                        <input 
                            id="terms" 
                            name="terms" 
                            type="checkbox" 
                            class="h-4 w-4 text-indigo-600 focus:ring-indigo-500 border-gray-300 rounded"
                        >
                        <label for="terms" class="ml-2 block text-sm text-gray-900">
                            I agree to the <a href="#" class="text-indigo-600 hover:text-indigo-500">Terms and Conditions</a> and <a href="#" class="text-indigo-600 hover:text-indigo-500">Privacy Policy</a>
                        </label>
                    </div>
                    <span id="terms-error" class="error-message text-red-500 text-sm">
                        <%= typeof errors !== 'undefined' && errors.terms ? errors.terms : '' %>
                    </span>
                    <div>
                        <button 
                            type="submit" 
                            class="group relative w-full flex justify-center py-3 px-4 border border-transparent rounded-lg shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500"
                        >
                            <span class="absolute left-0 inset-y-0 flex items-center pl-3">
                                <i class="fas fa-user-plus group-hover:text-indigo-400"></i>
                            </span>
                            Register as Conductor
                        </button>
                    </div>

                    <div class="text-sm text-center">
                        <span class="text-gray-600">Already have an account?</span>
                        <a href="/conductor/login" class="font-medium text-indigo-600 hover:text-indigo-500">
                            Sign in as Conductor
                        </a>
                    </div>
                </div>
            </form>
        </div>
    </div>
    <script>
            setTimeout(() => {
            const errorEls = document.querySelectorAll('.error');
            errorEls.forEach(err => {
            err.style.display = 'none';
            });
            }, 5000);
    </script>
    <script src="/js/conductorRegistration.js"></script>
